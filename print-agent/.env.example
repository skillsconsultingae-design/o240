# --- Supabase ---
# URL du projet (Dashboard Supabase > Project Settings > API)
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Cle service_role. Elle contourne RLS pour lire les commandes + mettre a jour le statut.
# ATTENTION : cette cle est puissante. Elle ne doit JAMAIS quitter ce PC du resto,
# ni etre mise dans le site / le front. Elle reste ici, en local, uniquement.
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# --- Imprimante ---
# Nom EXACT de l'imprimante tel qu'il apparait dans Windows > Peripheriques et imprimantes
# (apres installation du driver Epson APD). En general : "EPSON TM-T20II Receipt"
PRINTER_NAME=EPSON TM-T20II Receipt

# --- Infos resto (en-tete du ticket) ---
RESTO_NOM=LE NOM DU RESTO
RESTO_ADRESSE=12 rue de la Paix, 75002 Paris
RESTO_TEL=01 23 45 67 89

# --- Mentions legales (pied du ticket client, optionnel) ---
RESTO_SIRET=123 456 789 00012
RESTO_TVA_INTRA=FR01123456789
