# Copier en .env et remplir (Dashboard Supabase > Project Settings > API)
# Ces variables sont exposees cote navigateur (prefixe VITE_) : c'est normal,
# l'anon key est publique et protegee par RLS.
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Cle Google Maps (autocompletion adresse de livraison)
# Console Google Cloud > APIs & Services > Credentials.
# Pensez a restreindre la cle (referrers HTTP de votre domaine) car elle est
# exposee cote navigateur (prefixe VITE_).
VITE_GOOGLE_MAPS_API_KEY=AIza...
